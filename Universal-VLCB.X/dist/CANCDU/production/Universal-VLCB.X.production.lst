 47327                           ;Config register CONFIG1 @ 0x300000
 47328                           ;	External Oscillator Selection
 47329                           ;	FEXTOSC = HS, HS (crystal oscillator) above 8 MHz
 47330                           ;	Reset Oscillator Selection
 47331                           ;	RSTOSC = EXTOSC, EXTOSC operating per FEXTOSC bits (device manufacturing default)
 47332   300000                     	org	3145728
 47333   300000  FA                 	db	250
 47334                           
 47335                           ;Config register CONFIG2 @ 0x300001
 47336                           ;	Clock out Enable bit
 47337                           ;	CLKOUTEN = OFF, CLKOUT function is disabled
 47338                           ;	PRLOCKED One-Way Set Enable bit
 47339                           ;	PR1WAY = ON, PRLOCKED bit can be cleared and set only once
 47340                           ;	Clock Switch Enable bit
 47341                           ;	CSWEN = ON, Writing to NOSC and NDIV is allowed
 47342                           ;	JTAG Enable bit
 47343                           ;	JTAGEN = OFF, Disable JTAG Boundary Scan mode, JTAG pins revert to user functions
 47344                           ;	Fail-Safe Clock Monitor Enable bit
 47345                           ;	FCMEN = ON, Fail-Safe Clock Monitor enabled
 47346                           ;	Fail-Safe Clock Monitor -Primary XTAL Enable bit
 47347                           ;	FCMENP = ON, FSCM timer will set FSCMP bit and OSFIF interrupt on Primary XTAL failure
 47348                           ;	Fail-Safe Clock Monitor -Secondary XTAL Enable bit
 47349                           ;	FCMENS = ON, FSCM timer will set FSCMS bit and OSFIF interrupt on Secondary XTAL failu
      +                          re
 47350   300001                     	org	3145729
 47351   300001  EF                 	db	239
 47352                           
 47353                           ;Config register CONFIG3 @ 0x300002
 47354                           ;	MCLR Enable bit
 47355                           ;	MCLRE = EXTMCLR, If LVP = 0, MCLR pin is MCLR; If LVP = 1, RE3 pin function is MCLR
 47356                           ;	Power-up timer selection bits
 47357                           ;	PWRTS = PWRT_64, PWRT set at 64ms
 47358                           ;	Multi-vector enable bit
 47359                           ;	MVECEN = ON, Multi-vector enabled, Vector table used for interrupts
 47360                           ;	IVTLOCK bit One-way set enable bit
 47361                           ;	IVT1WAY = ON, IVTLOCKED bit can be cleared and set only once
 47362                           ;	Low Power BOR Enable bit
 47363                           ;	LPBOREN = OFF, Low-Power BOR disabled
 47364                           ;	Brown-out Reset Enable bits
 47365                           ;	BOREN = SBORDIS, Brown-out Reset enabled , SBOREN bit is ignored
 47366   300002                     	org	3145730
 47367   300002  FD                 	db	253
 47368                           
 47369                           ;Config register CONFIG4 @ 0x300003
 47370                           ;	Brown-out Reset Voltage Selection bits
 47371                           ;	BORV = VBOR_2P7, Brown-out Reset Voltage (VBOR) set to 2.7V
 47372                           ;	ZCD Disable bit
 47373                           ;	ZCD = OFF, ZCD module is disabled. ZCD can be enabled by setting the ZCDSEN bit of ZCD
      +                          CON
 47374                           ;	PPSLOCK bit One-Way Set Enable bit
 47375                           ;	PPS1WAY = ON, PPSLOCKED bit can be cleared and set only once; PPS registers remain loc
      +                          ked after one clear/set cycle
